        </mxCell>

        <!-- Re-loop note -->
        <mxCell id="reloop-note" value="🔄 RE-LOOP: AgentEndHookDecision(continue_run=True) from after_run() sends the agent back to the top of the main loop. The behavior can inject new prompt_fragments or append_prompt_fragments before the next iteration." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=2;" vertex="1" parent="1">
