        <mxCell id="sc-note" value="⚡ SHORT-CIRCUIT: AgentHookDecision(final_result) or ToolHookDecision(final_result) stops the chain and returns immediately without completing the remaining hooks or the loop iteration." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=2;" vertex="1" parent="1">
