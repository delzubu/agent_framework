<mxfile host="app.diagrams.net" modified="2026-03-31T00:00:00.000Z" agent="agent_framework architecture" version="21.0.0">
  <diagram name="Multi-Agent Orchestration" id="multi-agent-orchestration">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2000" pageHeight="1300" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Multi-Agent Orchestration — Hierarchical Call Flow" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="20" width="1000" height="40" as="geometry" />
        </mxCell>

        <!-- ===== ROOT AGENT ===== -->
        <mxCell id="root-agent" value="Root Agent&#xa;(caller_id = None)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="850" y="80" width="240" height="60" as="geometry" />
        </mxCell>

        <mxCell id="root-decide" value="Agent decides: call_subagent&#xa;decision.subagent_id = &quot;child_agent&quot;&#xa;decision.subagent_input = &quot;do X&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="820" y="165" width="300" height="70" as="geometry" />
        </mxCell>

        <!-- AgentHost dispatch -->
        <mxCell id="host-dispatch" value="AgentHost&#xa;dispatch_decision() → handle_subagent_call()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="820" y="260" width="300" height="55" as="geometry" />
        </mxCell>

        <!-- Sync vs Async fork -->
        <mxCell id="sync-async" value="Sync or Async?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="870" y="345" width="200" height="70" as="geometry" />
        </mxCell>

        <!-- Sync path -->
        <mxCell id="sync-call" value="host.call_subagent(&#xa;  callee_id, params&#xa;)&#xa;[synchronous, blocks]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="580" y="440" width="220" height="80" as="geometry" />
        </mxCell>

        <!-- Async path -->
        <mxCell id="async-call" value="host.call_subagent_async(&#xa;  callee_id, params&#xa;)&#xa;[ThreadPoolExecutor, non-blocking]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1140" y="440" width="240" height="80" as="geometry" />
        </mxCell>

        <!-- open_context -->
        <mxCell id="open-ctx" value="host.open_context(&#xa;  caller_id=parent_agent_id,&#xa;  callee_id=child_agent_id,&#xa;  kind=&quot;subagent_call&quot;&#xa;) → CallContext(status=&quot;open&quot;)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="820" y="550" width="300" height="95" as="geometry" />
        </mxCell>

        <!-- Child agent execution -->
        <mxCell id="child-agent" value="Child Agent Run&#xa;(caller_id = parent_agent_id)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="840" y="680" width="260" height="60" as="geometry" />
        </mxCell>

        <!-- Child can recurse or callback -->
        <mxCell id="child-actions" value="Child agent may:&#xa;A) call further sub-agents (nesting)&#xa;B) call tools&#xa;C) issue callbacks to parent&#xa;D) produce final_message → AgentResult" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="820" y="760" width="300" height="90" as="geometry" />
        </mxCell>

        <!-- ===== CALLBACK ESCALATION (left branch) ===== -->
        <mxCell id="cb-label" value="C) Callback path" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="860" width="200" height="25" as="geometry" />
        </mxCell>

        <mxCell id="cb-emit" value="Child emits AgentDecision&#xa;kind=&quot;callback&quot;&#xa;callback_intent=&quot;information_request&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fad7ac;strokeColor=#b46504;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="150" y="895" width="280" height="65" as="geometry" />
        </mxCell>

        <mxCell id="resolve-chain" value="3-Level Resolution Chain:&#xa;&#xa;Level 1: parent.respond_to_callback()&#xa;→ AgentBehavior.respond_to_callback()&#xa;→ first non-None wins&#xa;&#xa;Level 2: host.run_agent(parent_id, prompt)&#xa;→ run parent agent with callback&#xa;&#xa;Level 3: host.request_user_input(prompt)&#xa;→ Console I/O (output_writer / input_reader)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fad7ac;strokeColor=#b46504;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="980" width="380" height="175" as="geometry" />
        </mxCell>

        <mxCell id="cb-response" value="Response injected into child's&#xa;conversation_messages as {role:user}&#xa;+ prompt_fragment &lt;callback_response&gt;&#xa;Child loop continues" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="150" y="1180" width="280" height="80" as="geometry" />
        </mxCell>

        <!-- ===== RESULT RETURN (right branch) ===== -->
        <mxCell id="result-label" value="D) Final result path" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1400" y="760" width="200" height="25" as="geometry" />
        </mxCell>

        <mxCell id="agent-result" value="AgentResult(&#xa;  status=&quot;completed&quot;,&#xa;  message=final_message,&#xa;  decision=decision,&#xa;  prompt=rendered_prompt&#xa;)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1380" y="795" width="270" height="100" as="geometry" />
        </mxCell>

        <mxCell id="ctx-resolve" value="ctx.status = &quot;resolved&quot;&#xa;audit_tracer.finish(record)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1400" y="920" width="230" height="55" as="geometry" />
        </mxCell>

        <!-- Result injected into parent -->
        <mxCell id="parent-inject" value="Result injected into parent's prompt fragment:&#xa;&lt;subagent_result subagent=&quot;{id}&quot;&gt;&#xa;  {AgentResult.message}&#xa;&lt;/subagent_result&gt;&#xa;Parent loop continues" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1380" y="1000" width="300" height="100" as="geometry" />
        </mxCell>

        <!-- ===== CallContext tracking ===== -->
        <mxCell id="ctx-box" value="CallContext Tracking&#xa;&#xa;host._call_contexts: dict[str, CallContext]&#xa;&#xa;CallContext fields:&#xa;• context_id: UUID&#xa;• caller_id: str&#xa;• callee_id: str&#xa;• kind: str  (&quot;subagent_call&quot; | &quot;callback:{intent}&quot;)&#xa;• status: &quot;open&quot; | &quot;resolved&quot; | &quot;failed&quot;&#xa;• opened_at: datetime&#xa;• resolved_at: datetime | None" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1650" y="440" width="290" height="200" as="geometry" />
        </mxCell>

        <!-- ===== EDGES ===== -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;" edge="1" source="root-agent" target="root-decide" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;" edge="1" source="root-decide" target="host-dispatch" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;" edge="1" source="host-dispatch" target="sync-async" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" value="sync" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#9673a6;" edge="1" source="sync-async" target="sync-call" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="870" y="380" /><mxPoint x="690" y="380" /><mxPoint x="690" y="440" /></Array></mxGeometry>
        </mxCell>
        <mxCell id="e5" value="async" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#9673a6;" edge="1" source="sync-async" target="async-call" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1070" y="380" /><mxPoint x="1260" y="380" /><mxPoint x="1260" y="440" /></Array></mxGeometry>
        </mxCell>
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;" edge="1" source="sync-call" target="open-ctx" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="690" y="540" /><mxPoint x="690" y="590" /><mxPoint x="820" y="590" /></Array></mxGeometry>
        </mxCell>
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;" edge="1" source="async-call" target="open-ctx" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1260" y="540" /><mxPoint x="1260" y="590" /><mxPoint x="1120" y="590" /></Array></mxGeometry>
        </mxCell>
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;" edge="1" source="open-ctx" target="child-agent" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;" edge="1" source="child-agent" target="child-actions" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Callback branch -->
        <mxCell id="e10" value="callback" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#b46504;" edge="1" source="child-actions" target="cb-emit" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="820" y="805" /><mxPoint x="290" y="805" /><mxPoint x="290" y="895" /></Array></mxGeometry>
        </mxCell>
        <mxCell id="e11" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;" edge="1" source="cb-emit" target="resolve-chain" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;" edge="1" source="resolve-chain" target="cb-response" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e12b" value="resume child" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#82b366;dashed=1;" edge="1" source="cb-response" target="child-agent" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="290" y="1270" /><mxPoint x="290" y="1300" /><mxPoint x="970" y="1300" /><mxPoint x="970" y="760" /></Array></mxGeometry>
        </mxCell>
        <!-- Result branch -->
        <mxCell id="e13" value="final_message" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#82b366;" edge="1" source="child-actions" target="agent-result" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1120" y="805" /><mxPoint x="1515" y="805" /></Array></mxGeometry>
        </mxCell>
        <mxCell id="e14" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;" edge="1" source="agent-result" target="ctx-resolve" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e15" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;" edge="1" source="ctx-resolve" target="parent-inject" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e16" value="resume parent" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#82b366;dashed=1;" edge="1" source="parent-inject" target="root-agent" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1530" y="1100" /><mxPoint x="1530" y="1130" /><mxPoint x="1970" y="1130" /><mxPoint x="1970" y="110" /><mxPoint x="1090" y="110" /></Array></mxGeometry>
        </mxCell>
        <!-- CallContext side link -->
        <mxCell id="e17" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=open;endFill=0;dashed=1;" edge="1" source="open-ctx" target="ctx-box" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1120" y="597" /><mxPoint x="1795" y="597" /></Array></mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
