<mxfile host="app.diagrams.net" modified="2026-03-31T00:00:00.000Z" agent="agent_framework architecture" version="21.0.0">
  <diagram name="Callback Flow" id="callback-flow">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Callback Intent Flow and Resolution Chain" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="450" y="20" width="900" height="40" as="geometry" />
        </mxCell>

        <!-- === AGENT EMITTING CALLBACK === -->
        <mxCell id="agent-decision" value="Agent emits AgentDecision&#xa;kind=&#34;callback&#34;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="700" y="70" width="280" height="55" as="geometry" />
        </mxCell>

        <!-- 6 callback intents -->
        <mxCell id="intents-label" value="callback_intent is one of:" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="150" width="200" height="30" as="geometry" />
        </mxCell>

        <mxCell id="intent-info" value="information_request&#xa;Missing info after local retrieval" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fad7ac;strokeColor=#b46504;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="195" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="intent-proposal" value="proposal_review&#xa;Proposed answer needs review" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fad7ac;strokeColor=#b46504;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="280" y="195" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="intent-recovery" value="execution_recovery&#xa;Error needs caller decision" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fad7ac;strokeColor=#b46504;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="520" y="195" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="intent-return" value="delegation_return&#xa;Work complete/blocked" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fad7ac;strokeColor=#b46504;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="760" y="195" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="intent-policy" value="policy_or_approval&#xa;Sensitive action needs approval" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fad7ac;strokeColor=#b46504;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1000" y="195" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="intent-guardrail" value="guardrail_trip&#xa;Policy violation detected" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1240" y="195" width="220" height="60" as="geometry" />
        </mxCell>

        <!-- delegation_return special case note -->
        <mxCell id="delegation-note" value="NOTE: delegation_return normalizes to&#xa;kind=&#34;callback&#34; like all other intents.&#xa;Caller interprets it as work-complete signal." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="730" y="270" width="280" height="60" as="geometry" />
        </mxCell>

        <!-- === handle_callback() === -->
        <mxCell id="handle-callback" value="handle_callback()&#xa;Called from dispatch_decision()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fad7ac;strokeColor=#b46504;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="680" y="360" width="320" height="55" as="geometry" />
        </mxCell>

        <mxCell id="open-context" value="open_context(&#xa;  caller_id=self.agent_id,&#xa;  callee_id=caller_id or &#34;host&#34;,&#xa;  kind=&#34;callback:{intent}&#34;&#xa;) → CallContext(status=&#34;open&#34;)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="680" y="440" width="320" height="90" as="geometry" />
        </mxCell>

        <mxCell id="route-check" value="has caller_id&#xa;AND can_query_caller?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="720" y="560" width="240" height="80" as="geometry" />
        </mxCell>

        <!-- === Resolution Path: YES (has caller) === -->
        <mxCell id="resolve-callback-label" value="YES" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=12;fontStyle=1;fontColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="450" y="600" width="60" height="30" as="geometry" />
        </mxCell>

        <mxCell id="resolve-callback" value="host.resolve_callback(&#xa;  caller_id=caller_id,&#xa;  callee=self,&#xa;  prompt=decision.message&#xa;)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="350" y="660" width="250" height="90" as="geometry" />
        </mxCell>

        <!-- 3-level resolution chain -->
        <mxCell id="level1" value="Level 1: caller_agent.respond_to_callback(host, callee_id, prompt)&#xa;→ AgentBehavior.respond_to_callback()&#xa;→ First non-None response wins" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="780" width="360" height="75" as="geometry" />
        </mxCell>

        <mxCell id="level1-check" value="response?&#xa;(not None)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="90" y="885" width="160" height="70" as="geometry" />
        </mxCell>

        <mxCell id="level2" value="Level 2: host.run_agent(caller_id, prompt)&#xa;Run the caller agent with callback as instruction&#xa;→ AgentResult.message" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="985" width="360" height="65" as="geometry" />
        </mxCell>

        <mxCell id="level3" value="Level 3: Fallback&#xa;host.request_user_input(prompt)&#xa;Console I/O (output_writer + input_reader)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="1080" width="360" height="60" as="geometry" />
        </mxCell>

        <!-- === Resolution Path: NO (no caller) === -->
        <mxCell id="no-caller-label" value="NO" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=12;fontStyle=1;fontColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="1010" y="600" width="60" height="30" as="geometry" />
        </mxCell>

        <mxCell id="direct-input" value="host.request_user_input(decision.message)&#xa;Direct console prompt&#xa;(output_writer → user → input_reader)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1020" y="660" width="310" height="80" as="geometry" />
        </mxCell>

        <!-- === After resolution === -->
        <mxCell id="got-response" value="response: str obtained" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="660" y="800" width="280" height="50" as="geometry" />
        </mxCell>

        <mxCell id="resolve-ctx" value="ctx.status = &#34;resolved&#34;&#xa;audit_tracer.record_callback(response=response)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="660" y="875" width="280" height="60" as="geometry" />
        </mxCell>

        <mxCell id="append-response" value="Append to run:&#xa;• conversation_messages: {role:user, content:response}&#xa;• prompt_fragments: &lt;callback_response intent=...&gt;response&lt;/...&gt;&#xa;  (via _upsert_prompt_fragment)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="625" y="960" width="350" height="85" as="geometry" />
        </mxCell>

        <mxCell id="loop-continue" value="return None&#xa;Agent loop continues →&#xa;next build_context() will&#xa;include callback response" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="680" y="1075" width="280" height="70" as="geometry" />
        </mxCell>

        <!-- === EDGES === -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;" edge="1" source="agent-decision" target="handle-callback" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="840" y="150" /><mxPoint x="840" y="360" /></Array></mxGeometry>
        </mxCell>
        <mxCell id="e1b" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=open;endFill=0;dashed=1;" edge="1" source="agent-decision" target="intent-info" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="700" y="125" /><mxPoint x="150" y="125" /><mxPoint x="150" y="195" /></Array></mxGeometry>
        </mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;" edge="1" source="handle-callback" target="open-context" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;" edge="1" source="open-context" target="route-check" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" value="YES" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#82b366;" edge="1" source="route-check" target="resolve-callback" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="720" y="600" /><mxPoint x="475" y="600" /><mxPoint x="475" y="660" /></Array></mxGeometry>
        </mxCell>
        <mxCell id="e5" value="NO" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#b85450;" edge="1" source="route-check" target="direct-input" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="960" y="600" /><mxPoint x="1175" y="600" /><mxPoint x="1175" y="660" /></Array></mxGeometry>
        </mxCell>
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;" edge="1" source="resolve-callback" target="level1" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;" edge="1" source="level1" target="level1-check" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e8" value="YES" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#82b366;" edge="1" source="level1-check" target="got-response" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="250" y="920" /><mxPoint x="800" y="920" /><mxPoint x="800" y="850" /></Array></mxGeometry>
        </mxCell>
        <mxCell id="e9" value="NO" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;strokeColor=#b85450;" edge="1" source="level1-check" target="level2" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;" edge="1" source="level2" target="level3" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e11" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;" edge="1" source="level3" target="got-response" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="240" y="1110" /><mxPoint x="240" y="1160" /><mxPoint x="800" y="1160" /><mxPoint x="800" y="850" /></Array></mxGeometry>
        </mxCell>
        <mxCell id="e12" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;" edge="1" source="direct-input" target="got-response" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1175" y="780" /><mxPoint x="940" y="780" /><mxPoint x="940" y="825" /></Array></mxGeometry>
        </mxCell>
        <mxCell id="e13" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;" edge="1" source="got-response" target="resolve-ctx" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e14" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;" edge="1" source="resolve-ctx" target="append-response" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e15" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;" edge="1" source="append-response" target="loop-continue" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
