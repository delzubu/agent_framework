<mxfile host="app.diagrams.net" modified="2026-03-31T00:00:00.000Z" agent="agent_framework architecture" version="21.0.0">
  <diagram name="Agent Decision Loop" id="agent-decision-loop">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2000" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="Agent Decision Loop (Template Method Pattern)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="600" y="20" width="800" height="40" as="geometry" />
        </mxCell>

        <!-- === INITIALIZATION === -->
        <mxCell id="start" value="Agent.run(host, parameters, caller_id, ...)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="750" y="70" width="300" height="50" as="geometry" />
        </mxCell>

        <mxCell id="create-run" value="_create_run(parameters, ...)&#xa;→ AgentRun(run_id=UUID, rendered_prompt, &#xa;seed_parameters, empty state)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="720" y="150" width="360" height="70" as="geometry" />
        </mxCell>

        <mxCell id="refresh-params" value="refresh_parameter_state(run)&#xa;Extract XML-tagged params from prompt&#xa;→ run.parameter_values, missing, invalid" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="720" y="250" width="360" height="70" as="geometry" />
        </mxCell>

        <mxCell id="audit-start" value="[audit_tracer] start_agent_call(run_id, ...)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="720" y="350" width="360" height="45" as="geometry" />
        </mxCell>

        <!-- === PRE-AGENT HOOKS === -->
        <mxCell id="pre-agent-hooks" value="Pre-Agent Hooks&#xa;_run_pre_agent_hooks(run, caller_id)&#xa;&#xa;1. behaviors.before_run() → AgentHookDecision&#xa;2. onPreAgent callbacks → fires AgentStartEvent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="720" y="425" width="360" height="90" as="geometry" />
        </mxCell>

        <mxCell id="pre-agent-shortcircuit" value="AgentHookDecision&#xa;.final_result set?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1160" y="440" width="180" height="70" as="geometry" />
        </mxCell>

        <mxCell id="early-return" value="Return final_result&#xa;immediately" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1420" y="440" width="170" height="60" as="geometry" />
        </mxCell>

        <!-- === MAIN LOOP === -->
        <mxCell id="loop-guard" value="while should_continue(run)?&#xa;[always True by default]" style="rhombus;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="750" y="560" width="300" height="70" as="geometry" />
        </mxCell>

        <mxCell id="before-iteration" value="before_iteration(run)&#xa;• history.append(&#34;before_iteration:{id}&#34;)&#xa;• refresh_parameter_state(run)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="720" y="670" width="360" height="70" as="geometry" />
        </mxCell>

        <mxCell id="runtime-decision" value="runtime_decision = resolve_runtime_decision(run)&#xa;[returns None by default — subclass override point]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="720" y="770" width="360" height="60" as="geometry" />
        </mxCell>

        <mxCell id="runtime-check" value="runtime_decision&#xa;is None?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="780" y="860" width="240" height="70" as="geometry" />
        </mxCell>

        <!-- Build context + model call path -->
        <mxCell id="build-context" value="build_context(host, run)&#xa;→ ModelContext&#xa;(system_prompt + user_prompt + fragments&#xa;+ tools + subagents + history)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="520" y="975" width="280" height="80" as="geometry" />
        </mxCell>

        <mxCell id="pre-model-hooks" value="onPreModel hooks + host.run_pre_model_hooks()&#xa;fires ModelStartEvent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="520" y="1085" width="280" height="55" as="geometry" />
        </mxCell>

        <mxCell id="model-call" value="ModelDriver.decide(...)&#xa;→ ModelResponse" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="545" y="1170" width="230" height="55" as="geometry" />
        </mxCell>

        <mxCell id="post-model-hooks" value="onPostModel hooks + host.run_post_model_hooks()&#xa;fires ModelEndEvent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="520" y="1255" width="280" height="55" as="geometry" />
        </mxCell>

        <mxCell id="normalize" value="AgentDecision.from_model_response(response)&#xa;+ _normalize_decision_capabilities(decision)&#xa;Normalize kind, repair slot confusion" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="510" y="1340" width="300" height="70" as="geometry" />
        </mxCell>

        <!-- Dispatch diamond -->
        <mxCell id="dispatch" value="dispatch_decision()&#xa;decision.kind?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="760" y="1100" width="280" height="90" as="geometry" />
        </mxCell>

        <!-- === HANDLERS === -->

        <!-- final_message handler -->
        <mxCell id="handle-final" value="handle_final_message()&#xa;→ AgentResult(status=&#34;completed&#34;,&#xa;  message=decision.message)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1120" y="970" width="250" height="70" as="geometry" />
        </mxCell>

        <!-- callback handler -->
        <mxCell id="handle-callback" value="handle_callback()&#xa;open CallContext(kind=&#34;callback:{intent}&#34;)&#xa;has caller &amp; can_query_caller?&#xa;  YES → host.resolve_callback()&#xa;  NO  → host.request_user_input()&#xa;append response as fragment&#xa;→ None (loop continues)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fad7ac;strokeColor=#b46504;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1120" y="1070" width="250" height="120" as="geometry" />
        </mxCell>

        <!-- call_tool handler -->
        <mxCell id="handle-tool" value="handle_tool_call()&#xa;validate in allowed_tools&#xa;onPreTool hooks → ToolHookDecision&#xa;host.execute_tool(name, params)&#xa;onPostTool hooks&#xa;_upsert_prompt_fragment(result)&#xa;→ None (loop continues)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fad7ac;strokeColor=#b46504;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1120" y="1220" width="250" height="120" as="geometry" />
        </mxCell>

        <!-- call_subagent handler -->
        <mxCell id="handle-subagent" value="handle_subagent_call()&#xa;validate in allowed_child_agents&#xa;onPreSubagent hooks → SubagentHookDecision&#xa;host.call_subagent(callee_id, params)&#xa;onPostSubagent hooks&#xa;_upsert_prompt_fragment(result)&#xa;→ None (loop continues)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fad7ac;strokeColor=#b46504;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1120" y="1370" width="250" height="120" as="geometry" />
        </mxCell>

        <!-- after_iteration -->
        <mxCell id="after-iteration" value="after_iteration(run)&#xa;history.append(&#34;after_iteration:{id}&#34;)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1450" y="1120" width="270" height="55" as="geometry" />
        </mxCell>

        <!-- === POST-AGENT HOOKS === -->
        <mxCell id="result-check" value="result&#xa;is not None?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1480" y="1220" width="200" height="70" as="geometry" />
        </mxCell>

        <mxCell id="post-agent-hooks" value="Post-Agent Hooks&#xa;_run_post_agent_hooks(run, caller_id, result)&#xa;&#xa;1. behaviors.after_run() → AgentEndHookDecision | AgentResult&#xa;2. onPostAgent callbacks → fires AgentEndEvent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1440" y="1330" width="350" height="90" as="geometry" />
        </mxCell>

        <mxCell id="continue-run-check" value="AgentEndHookDecision&#xa;.continue_run = True?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1480" y="1460" width="220" height="70" as="geometry" />
        </mxCell>

        <!-- Final return -->
        <mxCell id="final-result" value="RETURN AgentResult" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1750" y="1460" width="180" height="50" as="geometry" />
        </mxCell>

        <!-- complete_without_result -->
        <mxCell id="complete-without" value="complete_without_result(run)&#xa;→ AgentResult(status=&#34;stopped&#34;)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="350" y="560" width="260" height="55" as="geometry" />
        </mxCell>

        <!-- Audit finish -->
        <mxCell id="audit-finish" value="[finally] audit_tracer.finish_agent_call(run_id)&#xa;Append JSONL record to output file" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="720" y="1560" width="360" height="55" as="geometry" />
        </mxCell>

        <!-- === EDGES === -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;endFill=1;" edge="1" source="start" target="create-run" parent="1">
